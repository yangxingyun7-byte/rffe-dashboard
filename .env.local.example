# ============================================================
# 飞书 API 配置
# ============================================================
# 步骤：
# 1. 打开 https://open.feishu.cn/app
# 2. 创建企业自建应用
# 3. 获取 App ID 和 App Secret
# 4. 在"权限管理"中添加以下权限：
#    - sheets:spreadsheet:readonly（读取电子表格）
# 5. 发布应用并审批通过
# ============================================================

FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
